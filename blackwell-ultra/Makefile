all: $(OUT)

ptx: $(SRC)
	$(NVCC) $(SRC) $(NVCCFLAGS) --ptx -o $(basename $(SRC)).ptx

sass: $(OUT)
	cuobjdump --dump-sass $(OUT) > $(basename $(SRC)).sass

run: $(OUT)
	$(RUN_CMD)

$(OUT): $(SRC)
	$(NVCC) $(SRC) $(NVCCFLAGS) -o $(OUT)

clean:
	rm -f $(OUT) $(basename $(SRC)).ptx $(basename $(SRC)).out
